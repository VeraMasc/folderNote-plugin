{
  "compilerOptions": {
    "paths": { "tslib": ["node_modules/tslib/tslib.d.ts"] },
    "baseUrl": "../",
    "inlineSourceMap": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "jsxFactory": "JSX.createElement",
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ],
    "outDir": "./plugin/",
  },

  "files": ["./plugin/main.ts"],
  "exclude": ["../.sharedModules/*"]

}
